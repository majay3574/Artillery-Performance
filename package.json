{
  "name": "artillery-project",
  "version": "1.0.0",
  "description": "Load testing project using Artillery",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "loadtest": "artillery run artillery.yml -o reports/report.json",
